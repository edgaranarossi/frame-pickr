# Docs directory - design/implementation specs kept local (decision 2026-05-30, see DECISIONS.md)
docs/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.venv/

# Secrets
.env

# Runtime output (frame cache PNGs land inside src/cache/ next to the code — see PLAN.md)
src/cache/*.png
src/test_output.txt

# Build artifacts (keep the build scripts themselves tracked; ignore PyInstaller junk)
dist/
build/*
!build/requirements.txt
!build/setup.py
!build/build.bat
*.spec
*.pyc

# IDE
.vscode/
.idea/
*.swp
*.swo

# User-specific files
*.log
*.ini

# Temporary files
*.tmp
*.temp
